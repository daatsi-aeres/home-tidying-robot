<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="tidybot">

  <!-- ==================== PROPERTIES ==================== -->
  <!-- Base dimensions (meters) -->
  <xacro:property name="base_length" value="0.50"/>
  <xacro:property name="base_width"  value="0.40"/>
  <xacro:property name="base_height" value="0.12"/>
  <xacro:property name="base_mass"   value="8.0"/>

  <!-- Wheel dimensions -->
  <xacro:property name="wheel_radius" value="0.075"/>
  <xacro:property name="wheel_width"  value="0.04"/>
  <xacro:property name="wheel_mass"   value="0.5"/>

  <!-- Wheel placement -->
  <xacro:property name="wheel_x_offset" value="0.17"/>
  <xacro:property name="wheel_y_offset" value="${base_width/2 + wheel_width/2 + 0.005}"/>
  <xacro:property name="wheel_z_offset" value="${-base_height/2}"/>

  <!-- Torso dimensions -->
  <xacro:property name="torso_width"  value="0.20"/>
  <xacro:property name="torso_depth"  value="0.15"/>
  <xacro:property name="torso_height" value="0.40"/>
  <xacro:property name="torso_mass"   value="3.0"/>

  <!-- Arm link dimensions -->
  <xacro:property name="upper_arm_length" value="0.25"/>
  <xacro:property name="upper_arm_radius" value="0.025"/>
  <xacro:property name="upper_arm_mass"   value="0.8"/>

  <xacro:property name="forearm_length" value="0.22"/>
  <xacro:property name="forearm_radius" value="0.022"/>
  <xacro:property name="forearm_mass"   value="0.6"/>

  <xacro:property name="wrist_link_length" value="0.10"/>
  <xacro:property name="wrist_link_radius" value="0.018"/>
  <xacro:property name="wrist_link_mass"   value="0.3"/>

  <!-- Gripper dimensions -->
  <xacro:property name="gripper_length" value="0.08"/>
  <xacro:property name="gripper_width"  value="0.06"/>
  <xacro:property name="gripper_height" value="0.03"/>
  <xacro:property name="gripper_mass"   value="0.2"/>

  <!-- Face panel -->
  <xacro:property name="face_width"  value="0.18"/>
  <xacro:property name="face_height" value="0.10"/>
  <xacro:property name="face_depth"  value="0.015"/>
  <xacro:property name="face_mass"   value="0.15"/>

  <!-- Colors -->
  <material name="dark_gray">
    <color rgba="0.3 0.3 0.3 1.0"/>
  </material>
  <material name="light_gray">
    <color rgba="0.7 0.7 0.7 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.2 0.4 0.8 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="orange">
    <color rgba="0.9 0.5 0.1 1.0"/>
  </material>
  <material name="white">
    <color rgba="0.95 0.95 0.95 1.0"/>
  </material>
  <material name="cyan_glow">
    <color rgba="0.0 0.9 0.9 1.0"/>
  </material>

  <!-- ==================== MACROS ==================== -->

  <!-- Box inertia macro -->
  <xacro:macro name="box_inertia" params="m w d h">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(h*h+d*d)/12}" ixy="0" ixz="0"
               iyy="${m*(w*w+h*h)/12}" iyz="0"
               izz="${m*(w*w+d*d)/12}"/>
    </inertial>
  </xacro:macro>

  <!-- Cylinder inertia macro -->
  <xacro:macro name="cylinder_inertia" params="m r l">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(3*r*r+l*l)/12}" ixy="0" ixz="0"
               iyy="${m*(3*r*r+l*l)/12}" iyz="0"
               izz="${m*r*r/2}"/>
    </inertial>
  </xacro:macro>

  <!-- Wheel macro -->
  <xacro:macro name="wheel" params="name x_pos y_pos">
    <link name="${name}_wheel_link">
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="dark_gray"/>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>0.8</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" l="${wheel_width}"/>
    </link>

    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}_wheel_link"/>
      <origin xyz="${x_pos} ${y_pos} ${wheel_z_offset}" rpy="${-pi/2} 0 0"/>
      <axis xyz="0 0 1"/>
      <dynamics damping="0.1" friction="0.05"/>
    </joint>
  </xacro:macro>

  <!-- ==================== BASE LINK ==================== -->
  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${base_mass}" w="${base_width}" d="${base_length}" h="${base_height}"/>
  </link>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius + base_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== WHEELS ==================== -->
  <xacro:wheel name="front_left"  x_pos="${wheel_x_offset}"  y_pos="${wheel_y_offset}"/>
  <xacro:wheel name="front_right" x_pos="${wheel_x_offset}"  y_pos="${-wheel_y_offset}"/>
  <xacro:wheel name="rear_left"   x_pos="${-wheel_x_offset}" y_pos="${wheel_y_offset}"/>
  <xacro:wheel name="rear_right"  x_pos="${-wheel_x_offset}" y_pos="${-wheel_y_offset}"/>

  <!-- ==================== TORSO ==================== -->
  <link name="torso_link">
    <visual>
      <origin xyz="0 0 ${torso_height/2}"/>
      <geometry>
        <box size="${torso_depth} ${torso_width} ${torso_height}"/>
      </geometry>
      <material name="light_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${torso_height/2}"/>
      <geometry>
        <box size="${torso_depth} ${torso_width} ${torso_height}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 ${torso_height/2}"/>
      <mass value="${torso_mass}"/>
      <inertia ixx="${torso_mass*(torso_height*torso_height+torso_depth*torso_depth)/12}" ixy="0" ixz="0"
               iyy="${torso_mass*(torso_width*torso_width+torso_height*torso_height)/12}" iyz="0"
               izz="${torso_mass*(torso_width*torso_width+torso_depth*torso_depth)/12}"/>
    </inertial>
  </link>

  <joint name="torso_joint" type="fixed">
    <parent link="base_link"/>
    <child link="torso_link"/>
    <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== FACE PANEL (LED Display) ==================== -->
  <link name="face_panel_link">
    <visual>
      <geometry>
        <box size="${face_depth} ${face_width} ${face_height}"/>
      </geometry>
      <material name="cyan_glow"/>
    </visual>
    <collision>
      <geometry>
        <box size="${face_depth} ${face_width} ${face_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${face_mass}" w="${face_width}" d="${face_depth}" h="${face_height}"/>
  </link>

  <joint name="face_panel_joint" type="fixed">
    <parent link="torso_link"/>
    <child link="face_panel_link"/>
    <origin xyz="${torso_depth/2 + face_depth/2} 0 ${torso_height + face_height/2 + 0.005}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== RIGHT ARM (3-DOF Actuated) ==================== -->
  <!-- Shoulder joint -->
  <link name="right_upper_arm_link">
    <visual>
      <origin xyz="0 0 ${-upper_arm_length/2}"/>
      <geometry>
        <cylinder radius="${upper_arm_radius}" length="${upper_arm_length}"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${-upper_arm_length/2}"/>
      <geometry>
        <cylinder radius="${upper_arm_radius}" length="${upper_arm_length}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 ${-upper_arm_length/2}"/>
      <mass value="${upper_arm_mass}"/>
      <inertia ixx="${upper_arm_mass*(3*upper_arm_radius*upper_arm_radius+upper_arm_length*upper_arm_length)/12}" ixy="0" ixz="0"
               iyy="${upper_arm_mass*(3*upper_arm_radius*upper_arm_radius+upper_arm_length*upper_arm_length)/12}" iyz="0"
               izz="${upper_arm_mass*upper_arm_radius*upper_arm_radius/2}"/>
    </inertial>
  </link>

  <joint name="right_shoulder_joint" type="revolute">
    <parent link="torso_link"/>
    <child link="right_upper_arm_link"/>
    <origin xyz="0 ${-torso_width/2 - upper_arm_radius - 0.01} ${torso_height - 0.02}" rpy="0 -1.0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="2.57" effort="20.0" velocity="1.0"/>
    <dynamics damping="1.0" friction="0.2"/>
  </joint>

  <!-- Elbow joint -->
  <link name="right_forearm_link">
    <visual>
      <origin xyz="0 0 ${-forearm_length/2}"/>
      <geometry>
        <cylinder radius="${forearm_radius}" length="${forearm_length}"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${-forearm_length/2}"/>
      <geometry>
        <cylinder radius="${forearm_radius}" length="${forearm_length}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 ${-forearm_length/2}"/>
      <mass value="${forearm_mass}"/>
      <inertia ixx="${forearm_mass*(3*forearm_radius*forearm_radius+forearm_length*forearm_length)/12}" ixy="0" ixz="0"
               iyy="${forearm_mass*(3*forearm_radius*forearm_radius+forearm_length*forearm_length)/12}" iyz="0"
               izz="${forearm_mass*forearm_radius*forearm_radius/2}"/>
    </inertial>
  </link>

  <joint name="right_elbow_joint" type="revolute">
    <parent link="right_upper_arm_link"/>
    <child link="right_forearm_link"/>
    <origin xyz="0 0 ${-upper_arm_length}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.35" upper="2.35" effort="15.0" velocity="1.0"/>
    <dynamics damping="0.8" friction="0.15"/>
  </joint>

  <!-- Wrist joint -->
  <link name="right_wrist_link">
    <visual>
      <origin xyz="0 0 ${-wrist_link_length/2}"/>
      <geometry>
        <cylinder radius="${wrist_link_radius}" length="${wrist_link_length}"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${-wrist_link_length/2}"/>
      <geometry>
        <cylinder radius="${wrist_link_radius}" length="${wrist_link_length}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 ${-wrist_link_length/2}"/>
      <mass value="${wrist_link_mass}"/>
      <inertia ixx="${wrist_link_mass*(3*wrist_link_radius*wrist_link_radius+wrist_link_length*wrist_link_length)/12}" ixy="0" ixz="0"
               iyy="${wrist_link_mass*(3*wrist_link_radius*wrist_link_radius+wrist_link_length*wrist_link_length)/12}" iyz="0"
               izz="${wrist_link_mass*wrist_link_radius*wrist_link_radius/2}"/>
    </inertial>
  </link>

  <joint name="right_wrist_joint" type="revolute">
    <parent link="right_forearm_link"/>
    <child link="right_wrist_link"/>
    <origin xyz="0 0 ${-forearm_length}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10.0" velocity="1.5"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- End-effector (flat plate, fixed to wrist) -->
  <link name="right_gripper_link">
    <visual>
      <origin xyz="0 0 ${-gripper_height/2}"/>
      <geometry>
        <box size="${gripper_length} ${gripper_width} ${gripper_height}"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${-gripper_height/2}"/>
      <geometry>
        <box size="${gripper_length} ${gripper_width} ${gripper_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${gripper_mass}" w="${gripper_width}" d="${gripper_length}" h="${gripper_height}"/>
  </link>

  <joint name="right_gripper_joint" type="fixed">
    <parent link="right_wrist_link"/>
    <child link="right_gripper_link"/>
    <origin xyz="0 0 ${-wrist_link_length}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== LEFT ARM (Cosmetic/Static) ==================== -->
  <link name="left_upper_arm_link">
    <visual>
      <origin xyz="0 0 ${-upper_arm_length/2}"/>
      <geometry>
        <cylinder radius="${upper_arm_radius}" length="${upper_arm_length}"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${-upper_arm_length/2}"/>
      <geometry>
        <cylinder radius="${upper_arm_radius}" length="${upper_arm_length}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 ${-upper_arm_length/2}"/>
      <mass value="${upper_arm_mass}"/>
      <inertia ixx="${upper_arm_mass*(3*upper_arm_radius*upper_arm_radius+upper_arm_length*upper_arm_length)/12}" ixy="0" ixz="0"
               iyy="${upper_arm_mass*(3*upper_arm_radius*upper_arm_radius+upper_arm_length*upper_arm_length)/12}" iyz="0"
               izz="${upper_arm_mass*upper_arm_radius*upper_arm_radius/2}"/>
    </inertial>
  </link>

  <joint name="left_shoulder_joint" type="fixed">
    <parent link="torso_link"/>
    <child link="left_upper_arm_link"/>
    <origin xyz="0 ${torso_width/2 + upper_arm_radius + 0.01} ${torso_height - 0.02}" rpy="0 0.3 0"/>
  </joint>

  <link name="left_forearm_link">
    <visual>
      <origin xyz="0 0 ${-forearm_length/2}"/>
      <geometry>
        <cylinder radius="${forearm_radius}" length="${forearm_length}"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${-forearm_length/2}"/>
      <geometry>
        <cylinder radius="${forearm_radius}" length="${forearm_length}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 ${-forearm_length/2}"/>
      <mass value="${forearm_mass}"/>
      <inertia ixx="${forearm_mass*(3*forearm_radius*forearm_radius+forearm_length*forearm_length)/12}" ixy="0" ixz="0"
               iyy="${forearm_mass*(3*forearm_radius*forearm_radius+forearm_length*forearm_length)/12}" iyz="0"
               izz="${forearm_mass*forearm_radius*forearm_radius/2}"/>
    </inertial>
  </link>

  <joint name="left_elbow_joint" type="fixed">
    <parent link="left_upper_arm_link"/>
    <child link="left_forearm_link"/>
    <origin xyz="0 0 ${-upper_arm_length}" rpy="0 -0.5 0"/>
  </joint>

  <link name="left_hand_link">
    <visual>
      <origin xyz="0 0 ${-gripper_height/2}"/>
      <geometry>
        <box size="${gripper_length} ${gripper_width} ${gripper_height}"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${-gripper_height/2}"/>
      <geometry>
        <box size="${gripper_length} ${gripper_width} ${gripper_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${gripper_mass}" w="${gripper_width}" d="${gripper_length}" h="${gripper_height}"/>
  </link>

  <joint name="left_hand_joint" type="fixed">
    <parent link="left_forearm_link"/>
    <child link="left_hand_link"/>
    <origin xyz="0 0 ${-forearm_length}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== CAMERA (on torso, facing forward) ==================== -->
  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.03 0.06 0.03"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.03 0.06 0.03"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="0.05" w="0.06" d="0.03" h="0.03"/>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="torso_link"/>
    <child link="camera_link"/>
    <origin xyz="${torso_depth/2 + 0.015} 0 ${torso_height * 0.7}" rpy="0 0 0"/>
  </joint>

  <link name="camera_optical_frame"/>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

  <!-- ==================== LIDAR (on top of base) ==================== -->
  <link name="lidar_link">
    <visual>
      <geometry>
        <cylinder radius="0.035" length="0.04"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.035" length="0.04"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="0.1" r="0.035" l="0.04"/>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.0 0 ${base_height/2 + 0.02}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== IMU (inside base) ==================== -->
  <link name="imu_link">
    <visual>
      <geometry>
        <box size="0.02 0.02 0.01"/>
      </geometry>
      <material name="black"/>
    </visual>
    <xacro:box_inertia m="0.01" w="0.02" d="0.02" h="0.01"/>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ==================== GAZEBO PLUGINS ==================== -->
  <gazebo>
    <!-- Skid-steer drive (4 wheels) -->
    <plugin filename="ignition-gazebo-diff-drive-system" name="ignition::gazebo::systems::DiffDrive">
      <left_joint>front_left_wheel_joint</left_joint>
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>front_right_wheel_joint</right_joint>
      <right_joint>rear_right_wheel_joint</right_joint>
      <wheel_separation>${2 * wheel_y_offset}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <max_linear_acceleration>2.5</max_linear_acceleration>
      <max_angular_acceleration>2.0</max_angular_acceleration>
      <max_linear_velocity>0.8</max_linear_velocity>
      <max_angular_velocity>1.0</max_angular_velocity>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <tf_topic>odom_tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <odom_publish_frequency>30</odom_publish_frequency>
    </plugin>

    <!-- Joint state publisher -->
    <plugin filename="ignition-gazebo-joint-state-publisher-system" name="ignition::gazebo::systems::JointStatePublisher">
      <topic>joint_states</topic>
      <joint_name>front_left_wheel_joint</joint_name>
      <joint_name>front_right_wheel_joint</joint_name>
      <joint_name>rear_left_wheel_joint</joint_name>
      <joint_name>rear_right_wheel_joint</joint_name>
      <joint_name>right_shoulder_joint</joint_name>
      <joint_name>right_elbow_joint</joint_name>
      <joint_name>right_wrist_joint</joint_name>
    </plugin>

    <!-- Arm joint position controllers -->
    <plugin filename="ignition-gazebo-joint-position-controller-system" name="ignition::gazebo::systems::JointPositionController">
      <joint_name>right_shoulder_joint</joint_name>
      <topic>right_shoulder_cmd</topic>
      <p_gain>30.0</p_gain>
      <i_gain>0.5</i_gain>
      <d_gain>5.0</d_gain>
      <cmd_max>20.0</cmd_max>
      <cmd_min>-20.0</cmd_min>
    </plugin>

    <plugin filename="ignition-gazebo-joint-position-controller-system" name="ignition::gazebo::systems::JointPositionController">
      <joint_name>right_elbow_joint</joint_name>
      <topic>right_elbow_cmd</topic>
      <p_gain>25.0</p_gain>
      <i_gain>0.5</i_gain>
      <d_gain>4.0</d_gain>
      <cmd_max>15.0</cmd_max>
      <cmd_min>-15.0</cmd_min>
    </plugin>

    <plugin filename="ignition-gazebo-joint-position-controller-system" name="ignition::gazebo::systems::JointPositionController">
      <joint_name>right_wrist_joint</joint_name>
      <topic>right_wrist_cmd</topic>
      <p_gain>15.0</p_gain>
      <i_gain>0.3</i_gain>
      <d_gain>3.0</d_gain>
      <cmd_max>10.0</cmd_max>
      <cmd_min>-10.0</cmd_min>
    </plugin>
    <!-- Ground truth pose publisher (publishes world poses of all links) -->
    <plugin filename="ignition-gazebo-pose-publisher-system" name="ignition::gazebo::systems::PosePublisher">
      <publish_link_pose>true</publish_link_pose>
      <publish_collision_pose>false</publish_collision_pose>
      <publish_visual_pose>false</publish_visual_pose>
      <publish_sensor_pose>false</publish_sensor_pose>
      <publish_nested_model_pose>false</publish_nested_model_pose>
      <use_pose_vector_msg>true</use_pose_vector_msg>
      <update_frequency>30</update_frequency>
    </plugin>
  </gazebo>

  <!-- Camera sensor -->
  <gazebo reference="camera_link">
    <sensor name="camera_sensor" type="camera">
      <always_on>true</always_on>
      <update_rate>15</update_rate>
      <topic>camera/image_raw</topic>
      <ignition_frame_id>camera_link</ignition_frame_id>
      <camera>
        <horizontal_fov>1.39626</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>10.0</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>

  <!-- LiDAR sensor -->
  <gazebo reference="lidar_link">
    <sensor name="lidar_sensor" type="gpu_lidar">
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <topic>scan</topic>
      <ignition_frame_id>lidar_link</ignition_frame_id>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0</min_angle>
            <max_angle>0</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.12</min>
          <max>8.0</max>
          <resolution>0.01</resolution>
        </range>
      </lidar>
    </sensor>
  </gazebo>

  <!-- Wheel friction/surface properties -->
  <gazebo reference="front_left_wheel_link">
    <mu1>1.0</mu1>
    <mu2>0.8</mu2>
  </gazebo>
  <gazebo reference="front_right_wheel_link">
    <mu1>1.0</mu1>
    <mu2>0.8</mu2>
  </gazebo>
  <gazebo reference="rear_left_wheel_link">
    <mu1>1.0</mu1>
    <mu2>0.8</mu2>
  </gazebo>
  <gazebo reference="rear_right_wheel_link">
    <mu1>1.0</mu1>
    <mu2>0.8</mu2>
  </gazebo>

  <!-- IMU sensor -->
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>50</update_rate>
      <topic>imu</topic>
      <ignition_frame_id>imu_link</ignition_frame_id>
    </sensor>
  </gazebo>

</robot>
